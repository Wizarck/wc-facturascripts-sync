{
  "name": "wizarck/wc-facturascripts-sync-wp",
  "description": "WordPress-side plugin of wc-facturascripts-sync: WC ↔ FS connector",
  "type": "wordpress-plugin",
  "license": "LGPL-3.0-or-later",
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.8",
    "monolog/monolog": "^3.5",
    "ramsey/uuid": "^4.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^10",
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "WcFacturascriptsSync\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WcFacturascriptsSync\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
